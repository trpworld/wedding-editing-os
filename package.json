{
  "name": "wedding-music-collection",
  "version": "1.0.0",
  "private": true,
  "description": "Mobile-first wedding music collection app with Next.js frontend and Express backend.",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "npm --prefix frontend run dev",
    "dev:api": "nodemon backend/src/server.js",
    "build": "npm --prefix frontend run build",
    "start": "concurrently \"npm:start:api\" \"npm:start:web\"",
    "start:web": "npm --prefix frontend run start",
    "start:api": "node backend/src/server.js",
    "lint": "next lint frontend"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@prisma/client": "^7.8.0",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.20",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.9.0",
    "bullmq": "^5.76.6",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^11.15.0",
    "fs-extra": "^11.2.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "multer": "^2.0.2",
    "nanoid": "^5.0.9",
    "next": "^16.2.6",
    "nodemon": "^3.1.9",
    "postcss": "^8.5.10",
    "prisma": "^7.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sanitize-filename": "^1.6.3",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^3.4.17",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.6"
  }
}
